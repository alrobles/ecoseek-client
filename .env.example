# ecoseek-client configuration
# Copy this to .env and fill in your values.

# ── AgenticPlug ──────────────────────────────────────────────
# URL of the AgenticPlug connector running on your machine or network.
AGENTICPLUG_URL=http://localhost:3100

# Session token — paste directly OR use session file below.
# AGENTICPLUG_SESSION=YOUR_SESSION_TOKEN_HERE

# Path to AgenticPlug session JSON file (produced by `agenticplug login`).
AGENTICPLUG_SESSION_FILE=~/.config/agenticplug/session.json

# ── Hermes ───────────────────────────────────────────────────
# Hermes scientific agent gateway (via Cloudflare tunnel).
HERMES_GATEWAY_URL=https://hermes.ecoseek.org

# Orchestration timeout in seconds. Complex SDMs can take minutes.
HERMES_TIMEOUT=600

# ── HPC (KU Slurm) ──────────────────────────────────────────
# Only needed for HPC-aware tasks (hpc.status, hpc.queue, etc.).
# HPC_HOST=remote-hostname
# HPC_USER=your_ku_username

# ── Model providers (optional, for direct LLM access) ────────
# DeepSeek BYOK (bring your own key).
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions

# ── Logging ──────────────────────────────────────────────────
# ECOSEEK_LOG_LEVEL=INFO
# ECOSEEK_LOG_FILE=~/.ecoseek/logs/client.log
